{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gtfsscorecard.org/schemas/artifact.schema.json",
  "title": "GTFS Scorecard per-agency artifact",
  "description": "One agency's complete scored result for one snapshot (latest.json and <date>.json). The core contract is publish.build_artifact; the optional blocks are attached by the collect run. The top level is closed: adding a key requires updating this schema, which is the enforcement point.",
  "type": "object",
  "required": [
    "schema_version",
    "rubric_version",
    "validator_version",
    "agency",
    "generated_at",
    "snapshot_date",
    "feed",
    "overall",
    "categories",
    "top_fixes"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "rubric_version": {
      "type": "string"
    },
    "validator_version": {
      "type": [
        "string",
        "null"
      ],
      "description": "MobilityData gtfs-validator release that produced the correctness notices; null when correctness was not measured."
    },
    "agency": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "country": {
          "type": "string",
          "enum": [
            "US",
            "CA"
          ],
          "description": "ISO 3166-1 alpha-2 country code; omitted for US agencies so their artifacts stay byte-identical."
        },
        "operating_note": {
          "type": "string",
          "description": "Curator-verified operating status, mainly for long-expired feeds; omitted when empty."
        },
        "ntd_note": {
          "type": "string",
          "description": "Curator-recorded NTD reporting arrangement (shared feed, waiver); omitted when empty."
        },
        "state": {
          "type": "string",
          "description": "US state or territory; omitted when unlocated."
        }
      },
      "additionalProperties": false
    },
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp derived from the snapshot date, so re-running a day is byte-identical."
    },
    "snapshot_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "feed": {
      "type": "object",
      "required": [
        "static_url",
        "sha256",
        "size_bytes",
        "license_note",
        "reachable"
      ],
      "properties": {
        "static_url": {
          "type": "string"
        },
        "sha256": {
          "type": "string"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "license_note": {
          "type": "string"
        },
        "reachable": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "fetch": {
      "type": "object",
      "required": [
        "source",
        "final_url",
        "user_agent"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "final_url": {
          "type": "string"
        },
        "user_agent": {
          "type": "string"
        },
        "max_attempts": {
          "type": "integer"
        },
        "origin_error": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "overall": {
      "type": "object",
      "required": [
        "score",
        "grade"
      ],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "grade": {
          "type": "string",
          "enum": [
            "A",
            "B",
            "C",
            "D",
            "F"
          ]
        },
        "margin_to_next_band": {
          "type": [
            "number",
            "null"
          ]
        },
        "margin_to_lower_band": {
          "type": [
            "number",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "categories": {
      "type": "object",
      "required": [
        "correctness",
        "freshness",
        "completeness",
        "realtime"
      ],
      "properties": {
        "correctness": {
          "$ref": "#/$defs/category"
        },
        "freshness": {
          "$ref": "#/$defs/category"
        },
        "completeness": {
          "$ref": "#/$defs/category"
        },
        "realtime": {
          "$ref": "#/$defs/category"
        }
      },
      "additionalProperties": false
    },
    "top_fixes": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/finding",
        "required": [
          "rank"
        ]
      }
    },
    "confidence": {
      "type": "object",
      "description": "Measurement-confidence read (EXP-01): how much of this grade the pipeline could measure this run and from what source. A legibility layer on the one grade, never a second grade; absent on artifacts published before schema 1.5.",
      "required": [
        "level",
        "measured_categories",
        "total_categories",
        "fetch_source",
        "rt_windows",
        "feed_age_days",
        "notes"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "provisional",
            "medium",
            "high"
          ]
        },
        "measured_categories": {
          "type": "integer",
          "minimum": 0
        },
        "total_categories": {
          "type": "integer",
          "minimum": 0
        },
        "fetch_source": {
          "type": "string"
        },
        "rt_windows": {
          "type": "integer",
          "minimum": 0
        },
        "feed_age_days": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "recommendations": {
      "type": "array",
      "description": "Beyond-the-grade opportunities (Fares v2, Flex, accessibility); zero-deduction."
    },
    "conformance": {
      "type": "object",
      "description": "Conformance-mark credential over the scores (conformance.assess)."
    },
    "geo": {
      "type": "object",
      "description": "Median stop point + bbox for the national map; absent when the feed has no located stops."
    },
    "route_map": {
      "type": "object",
      "description": "Compact route/stop geometry summary; the drawable GeoJSON lives in geometry.geojson."
    },
    "routability": {
      "type": "object",
      "description": "Zero-deduction routing usability checks (single-stop trips, orphan stops)."
    },
    "ntd_id_alignment": {
      "type": "object",
      "description": "GTFS agency_id vs NTD ID alignment; US agencies only (ADR 0026)."
    },
    "ntd_readiness": {
      "type": "object",
      "description": "NTD certification readiness (published / valid / current); US agencies only."
    },
    "autofix": {
      "type": "object",
      "description": "Corrected-feed offer: what the safe deterministic fixes changed, and where the patched zip lives."
    },
    "recompute": {
      "type": "object",
      "description": "Freshness-sweep provenance: when and why the artifact was reswept without a refetch."
    }
  },
  "additionalProperties": false,
  "$defs": {
    "category": {
      "type": "object",
      "required": [
        "name",
        "status",
        "weight",
        "summary"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "measured",
            "not_yet_measured"
          ]
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "summary": {
          "type": "string"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "details": {
          "type": "object"
        }
      },
      "additionalProperties": false,
      "if": {
        "properties": {
          "status": {
            "const": "measured"
          }
        }
      },
      "then": {
        "required": [
          "score",
          "findings",
          "details"
        ]
      }
    },
    "finding": {
      "type": "object",
      "required": [
        "code",
        "severity",
        "count",
        "what",
        "why",
        "fix",
        "effort",
        "points",
        "owner"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "ERROR",
            "WARNING",
            "INFO"
          ]
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "what": {
          "type": "string"
        },
        "why": {
          "type": "string"
        },
        "fix": {
          "type": "string"
        },
        "effort": {
          "type": "string"
        },
        "points": {
          "type": "number",
          "minimum": 0
        },
        "owner": {
          "type": "string"
        },
        "rank": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3,
          "description": "1-based position in top_fixes; present only there."
        }
      },
      "additionalProperties": false
    }
  }
}
